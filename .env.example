# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SlipOK Payment Slip Verification
# Get these from SlipOK: https://www.slipok.com/
SLIPOK_API_URL=https://api.slipok.com/api/line/apikey/YOUR_API_KEY_ID
SLIPOK_API_KEY=your-slipok-api-key-here

# SlipOK Test Mode
# Set to true to auto-approve payments during testing (bypasses actual API calls)
# Set to false for production to use real SlipOK verification
SLIPOK_TEST_MODE=true
